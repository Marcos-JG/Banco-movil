# ========================================
# CONFIGURACIÓN DE APIs - BACKEND
# ========================================
# En Railway, estas variables se configuran en el dashboard del proyecto
# como variables de entorno. Se inyectan en tiempo de BUILD (npx expo export),
# así que si cambian hay que redeploy.
# ========================================

# AuthService - Autenticación y Gestión de Usuarios
EXPO_PUBLIC_AUTH_URL=

# Gestor Bancario Backend - Cuentas, Transacciones, Servicios, etc.
EXPO_PUBLIC_BANK_URL=

# Health check del Gestor Bancario
EXPO_PUBLIC_BANK_HEALTH_URL=

